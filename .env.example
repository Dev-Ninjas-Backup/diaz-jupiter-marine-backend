NODE_ENV=development
PORT=5052

DATABASE_URL=postgresql://user:password@localhost:5432/diaz_jupiter_marine

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

MAIL_USER=your_email@gmail.com
MAIL_PASS=your_email_app_password

REDIS_HOST=localhost
REDIS_PORT=6379

SUPER_ADMIN_EMAIL=admin@jupitermarinesales.com
SUPER_ADMIN_PASS=your_super_admin_password

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=your_s3_bucket_name

SERVICE_BOATS_KEY=your_service_boats_key
API_BOATS_KEY=your_api_boats_key

# Inventory listings (same feed shape as boats.com; Jupiter production uses the site API)
BOATS_COM_API_URL=https://jupitermarinesales.com/api/boats-com

# YachtBroker vessel list (full URL; sync uses page & per_page=15)
YACHTBROKER_API_URL=https://jupitermarinesales.com/api/yachtbroker/vessel
YACHTBROKER_API_KEY=your_yachtbroker_api_key
YACHTBROKER_BROKER_ID=your_broker_id

GMC_MERCHANT_ID=your_gmc_merchant_id
GMC_CLIENT_EMAIL=your_gmc_client_email
GMC_PRIVATE_KEY=your_gmc_private_key

PRODUCT_DETAILS_BASE_URL=https://jupitermarinesales.com/boats

BASE_URL=http://localhost:5052
